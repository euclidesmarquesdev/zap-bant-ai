rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // MASTER ACCESS: O e-mail abaixo tem acesso total e irrestrito ao sistema
    function isMasterUser() {
      return isAuthenticated() && 
             "email" in request.auth.token &&
             (request.auth.token.email.lower() == "euclidesmarques.dev@gmail.com");
    }

    match /{document=**} {
      allow read, write: if isMasterUser();
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && (
        isMasterUser() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin')
      );
    }

    function isOrgMember(orgId) {
      return isAuthenticated() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)))
      );
    }

    function isOrgAdmin(orgId) {
      return isAuthenticated() && (
        isSuperAdmin() || 
        (exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data.role == 'admin') ||
        (exists(/databases/$(database)/documents/organizations/$(orgId)) &&
         get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerUid == request.auth.uid)
      );
    }

    function isOrgAgent(orgId) {
      return isOrgMember(orgId) && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data.role == 'agent')
      );
    }

    // Global Users (Mapping UID to Org)
    match /users/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin();
      allow write: if isOwner(userId) || isSuperAdmin();
    }

    // Organizations
    match /organizations/{orgId} {
      allow list: if isAuthenticated();
      allow get: if isAuthenticated(); // Permite get por ID para validação de tokens/IDs no convite
      allow create: if isAuthenticated(); // Anyone can create an org
      allow update, delete: if isOrgAdmin(orgId);

      // Users within Org
      match /users/{userId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgAdmin(orgId) || isSuperAdmin() ||
                      (isOwner(userId) && request.resource.data.orgId == orgId);
      }

      // Leads within Org
      match /leads/{leadId} {
        allow read: if isOrgAdmin(orgId) || (isOrgAgent(orgId) && resource.data.assignedTo == request.auth.uid);
        allow write: if isOrgMember(orgId) || isAuthenticated(); // AI Agent needs to write

        match /messages/{messageId} {
          allow read: if isOrgAdmin(orgId) || (isOrgAgent(orgId) && get(/databases/$(database)/documents/organizations/$(orgId)/leads/$(leadId)).data.assignedTo == request.auth.uid);
          allow write: if isOrgMember(orgId) || isAuthenticated();
        }
      }

      // Agents (AI Models) within Org
      match /agents/{agentId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgAdmin(orgId);
      }

      // Settings within Org
      match /settings/{settingId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgAdmin(orgId);
      }

      // Human Agents within Org
      match /human_agents/{agentId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgAdmin(orgId);
      }
    }
  }
}
