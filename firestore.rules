rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Acesso Super Admin baseado em DOCUMENTO no banco de dados
    function isSuperAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
      );
    }
    
    function isOrgMember(orgId) {
      return isAuthenticated() && (
        isSuperAdmin() ||
        exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid))
      );
    }

    function isOrgAdmin(orgId) {
      return isAuthenticated() && (
        isSuperAdmin() || 
        (exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data.role == 'admin') ||
        (exists(/databases/$(database)/documents/organizations/$(orgId)) &&
         get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerUid == request.auth.uid)
      );
    }

    // Global Users (Mapping UID to Org)
    match /users/{userId} {
      // Regra básica: cada um lê e escreve o seu sem funções extras para evitar recursão inicial
      allow get: if isAuthenticated() && request.auth.uid == userId;
      allow list: if isAuthenticated();
      
      // Super Admin pode ler qualquer um
      allow read: if isSuperAdmin();

      allow create: if isAuthenticated() && (request.auth.uid == userId) && (
        (request.resource.data.role == 'super_admin' && request.resource.data.bootstrapToken == "admin123") ||
        (request.resource.data.role != 'super_admin')
      );
      
      allow update: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
    }

    // Organizations
    match /organizations/{orgId} {
      allow list: if isAuthenticated();
      allow get: if isAuthenticated(); 
      allow create: if isAuthenticated(); 
      allow update, delete: if isOrgAdmin(orgId);

      // Users within Org
      match /users/{userId} {
        // Permitimos o usuário ler seu próprio doc na org sem chamar isOrgMember
        allow read: if isAuthenticated() && (request.auth.uid == userId || isOrgMember(orgId));
        allow write: if isOrgAdmin(orgId) || isSuperAdmin() ||
                      (request.auth.uid == userId && (
                        request.resource.data.orgId == orgId ||
                        request.resource.data.bootstrapToken == "admin123"
                      ));
      }

      // Outras coleções
      match /{allSubcollections=**} {
         allow read: if isOrgMember(orgId);
         allow write: if isOrgAdmin(orgId);
      }
      
      // Leads & Messages
      match /leads/{leadId} {
        allow write: if isAuthenticated();
        // Permite que o lead seja criado por qualquer pessoa (público)
        // mas lido apenas por membros da org
        allow read: if isOrgMember(orgId);

        match /messages/{messageId} {
          allow write: if isAuthenticated();
          allow read: if isOrgMember(orgId);
        }
      }
    }
  }
}
