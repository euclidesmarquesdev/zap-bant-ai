rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Acesso Super Admin baseado em DOCUMENTO no banco de dados
    // Isso remove a necessidade de e-mails fixos no código das regras
    function isSuperAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
      );
    }

    // Regra Global para Super Admins
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
    
    function isOrgMember(orgId) {
      return isAuthenticated() && (
        isSuperAdmin() ||
        exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid))
      );
    }

    function isOrgAdmin(orgId) {
      return isAuthenticated() && (
        isSuperAdmin() || 
        (exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data.role == 'admin') ||
        (exists(/databases/$(database)/documents/organizations/$(orgId)) &&
         get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerUid == request.auth.uid)
      );
    }

    function isOrgAgent(orgId) {
      return isAuthenticated() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/organizations/$(orgId)/users/$(request.auth.uid)).data.role == 'agent')
      );
    }

    // Global Users (Mapping UID to Org)
    match /users/{userId} {
      allow list: if isAuthenticated();
      allow get: if isOwner(userId) || isSuperAdmin();
      
      // BOOTSTRAP RULE: Permite que o primeiro Super Admin se registre usando a Senha Master
      // como um token de validação. Isso elimina o e-mail fixo.
      allow create, update: if isOwner(userId) && (
        isSuperAdmin() || 
        (request.resource.data.role == 'super_admin' && request.resource.data.bootstrapToken == "admin123") ||
        (request.resource.data.role != 'super_admin')
      );
    }

    // Organizations
    match /organizations/{orgId} {
      allow list: if isAuthenticated();
      allow get: if isAuthenticated(); 
      allow create: if isAuthenticated(); 
      allow update, delete: if isOrgAdmin(orgId);

      // Users within Org
      match /users/{userId} {
        allow read: if isOrgMember(orgId);
        // Permite bootstrap da Org Master também usando o token
        allow write: if isOrgAdmin(orgId) || isSuperAdmin() ||
                      (isOwner(userId) && (
                        request.resource.data.orgId == orgId ||
                        request.resource.data.bootstrapToken == "admin123"
                      ));
      }

      // Outras coleções seguem a lógica de sub-membros
      match /{allSubcollections=**} {
         allow read: if isOrgMember(orgId);
         allow write: if isOrgAdmin(orgId);
      }
      
      // Leads & Messages (Acesso especial para agentes)
      match /leads/{leadId} {
        allow write: if isAuthenticated();
        match /messages/{messageId} {
          allow write: if isAuthenticated();
        }
      }
    }
  }
}
